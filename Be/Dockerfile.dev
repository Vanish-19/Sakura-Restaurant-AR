FROM node:22-alpine

WORKDIR /app

# Sao chép package.json
COPY package.json ./

# Cài đặt toàn bộ dependencies bên trong container
RUN npm install

# Sao chép toàn bộ mã nguồn
COPY . .

# Expose cổng của API server
EXPOSE 3000

# Chạy backend ở chế độ phát triển (hot-reloads khi thay đổi code ở máy thật)
CMD ["npm", "run", "dev"]
